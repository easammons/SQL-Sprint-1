-- All workouts
SELECT * FROM workouts;
 
-- Total training volume per week (sets * reps * weight)
-- Bodyweight exercises (NULL weight) count as 0
SELECT
    strftime('%Y-W%W', workout_date) AS week,
    SUM(sets * reps * COALESCE(weight, 0)) AS total_volume
FROM workouts
GROUP BY week
ORDER BY week;
 
-- Volume per exercise per week
SELECT
    strftime('%Y-W%W', workout_date) AS week,
    exercise,
    SUM(sets * reps * COALESCE(weight, 0)) AS volume
FROM workouts
GROUP BY week, exercise
ORDER BY week, exercise;
 
-- Total volume per week, excluding bodyweight movements
SELECT
    strftime('%Y-W%W', workout_date) AS week,
    SUM(sets * reps * weight) AS total_volume
FROM workouts
WHERE weight IS NOT NULL
GROUP BY week;
 
-- Max weight lifted per exercise (progression tracking)
SELECT exercise, MAX(weight) AS max_weight
FROM workouts
GROUP BY exercise;
 
-- All workouts for a specific exercise
SELECT * FROM workouts WHERE exercise = 'Squat';
 
-- Workouts in a date range
SELECT * FROM workouts WHERE workout_date >= '2026-07-01';

UPDATE workouts
SET weight = 145.0
WHERE workout_date = '2026-07-08' AND exercise = 'Bench Press';


UPDATE workouts
SET notes = 'Added later: form felt off on last rep'
WHERE id = 5;
 
-- Verify the update took effect
SELECT * FROM workouts WHERE workout_date = '2026-07-08' AND exercise = 'Bench Press';

DELETE FROM workouts WHERE id = 27;
 
-- Example: remove all workouts for an exercise you stopped doing
DELETE FROM workouts WHERE exercise = 'Calf Raise';
 
-- Verify the delete took effect
SELECT * FROM workouts WHERE exercise = 'Calf Raise';


-- Average weight lifted per exercise
SELECT exercise, AVG(weight) AS avg_weight
FROM workouts
WHERE weight IS NOT NULL
GROUP BY exercise;
 
-- Number of times each exercise was logged
SELECT exercise, COUNT(*) AS times_logged
FROM workouts
GROUP BY exercise
ORDER BY times_logged DESC;
 
-- Combine multiple aggregates in one summary query per exercise
SELECT
    exercise,
    COUNT(*) AS times_logged,
    AVG(weight) AS avg_weight,
    MAX(weight) AS max_weight,
    SUM(sets * reps * COALESCE(weight, 0)) AS total_volume
FROM workouts
GROUP BY exercise
ORDER BY exercise;

